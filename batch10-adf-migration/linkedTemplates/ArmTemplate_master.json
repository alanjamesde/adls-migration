{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "batch10-adf-migration"
		},
		"LS_ADLS_Batch10_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Batch10'"
		},
		"LS_ADLS_Batch10_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://batch10adlsstorage.dfs.core.windows.net/"
		},
		"LS_KeyVault_Batch10_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://batch10-kv-migration.vault.azure.net/"
		},
		"LS_OnPremSQL_Batch10_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "LAPTOP-S1T2JNQD\\SQLEXPRESS"
		},
		"LS_OnPremSQL_Batch10_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "migration_project"
		},
		"LS_OnPremSQL_Batch10_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "alan"
		},
		"integrationRuntime1_properties_typeProperties_linkedInfo_resourceId": {
			"type": "string",
			"defaultValue": "/subscriptions/1b66ef6c-baef-4ad1-97c3-eedf9131c9b1/resourcegroups/rg_dev_alanproject/providers/Microsoft.DataFactory/factories/adfdevalanproject/integrationruntimes/LAPTOP-S1T2JNQD-SQLEXPRESS"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "batch10-adf-migration_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Batch10_accountKey": {
						"value": "[parameters('LS_ADLS_Batch10_accountKey')]"
					},
					"LS_KeyVault_Batch10_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_Batch10_properties_typeProperties_baseUrl')]"
					},
					"integrationRuntime1_properties_typeProperties_linkedInfo_resourceId": {
						"value": "[parameters('integrationRuntime1_properties_typeProperties_linkedInfo_resourceId')]"
					},
					"LS_ADLS_Batch10_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Batch10_properties_typeProperties_url')]"
					},
					"LS_OnPremSQL_Batch10_properties_typeProperties_server": {
						"value": "[parameters('LS_OnPremSQL_Batch10_properties_typeProperties_server')]"
					},
					"LS_OnPremSQL_Batch10_properties_typeProperties_database": {
						"value": "[parameters('LS_OnPremSQL_Batch10_properties_typeProperties_database')]"
					},
					"LS_OnPremSQL_Batch10_properties_typeProperties_userName": {
						"value": "[parameters('LS_OnPremSQL_Batch10_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}